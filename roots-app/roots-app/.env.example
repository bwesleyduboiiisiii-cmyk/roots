# Copy this file to .env.local and fill in real values
# Get the Supabase values from your Supabase project: Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Your family's shared password - change this!
FAMILY_PASSWORD=change-this-to-something-your-family-knows

# A random secret for signing the login cookie - generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-long-random-string

# Copy this file to .env.local and fill in real values
# Get the Supabase values from your Supabase project: Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# A random secret for signing the login cookie - generate with: openssl rand -base64 32
# This signs session cookies. Changing it logs everyone out. Do not commit this.
AUTH_SECRET=replace-with-long-random-string
